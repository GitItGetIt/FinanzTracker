<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="de.fintracker.controller.ChartController">

    <top>
        <HBox spacing="20">
            <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Button text="Zurück" onAction="#goToMain" styleClass="action-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="40">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- PieChart: Ausgaben nach Kategorie -->
            <PieChart fx:id="expensePieChart" title="Ausgaben nach Kategorie"/>

            <!-- BarChart: Einnahmen/Ausgaben pro Monat -->
            <BarChart fx:id="monthlyBarChart">
                <xAxis>
                    <CategoryAxis label="Monat"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Betrag (€)"/>
                </yAxis>
            </BarChart>

        </VBox>
    </center>

</BorderPane>

