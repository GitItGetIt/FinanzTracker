<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="de.fintracker.controller.ExpenseController"
      spacing="15">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Überschrift -->
    <Label text="Ausgaben" style="-fx-font-size: 22px; -fx-font-weight: bold;" />

    <!-- Eingabebereich -->
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="120" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <children>
        <Label text="Betrag:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="amountField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Kategorie:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="categoryBox" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Datum:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="datePicker" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Notiz:" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
        <TextArea fx:id="noteArea" prefRowCount="3" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </children>
    </GridPane>

    <HBox spacing="10">
        <Button text="Speichern" onAction="#saveExpense"/>
        <Button text="Zurück" onAction="#goToMain"/>
    </HBox>

    <TableView fx:id="expenseTable" prefHeight="250">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
            <TableColumn fx:id="amountColumn" text="Betrag" prefWidth="100"/>
            <TableColumn fx:id="categoryColumn" text="Kategorie" prefWidth="150"/>
            <TableColumn fx:id="dateColumn" text="Datum" prefWidth="120"/>
            <TableColumn fx:id="noteColumn" text="Notiz" prefWidth="200"/>
        </columns>
    </TableView>

</VBox>
