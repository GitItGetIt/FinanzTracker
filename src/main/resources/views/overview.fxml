<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="de.fintracker.controller.OverviewController"
      spacing="15">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Überschrift -->
    <Label text="Übersicht" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <!-- Buttons -->
    <HBox spacing="10">
        <Button text="Einnahmen" onAction="#goToIncome"/>
        <Button text="Ausgaben" onAction="#goToExpense"/>
        <Button text="Zurück" onAction="#goToMain"/>
    </HBox>

    <!-- Tabelle -->
    <TableView fx:id="overviewTable" prefHeight="350">
        <columns>
            <TableColumn fx:id="typeColumn" text="Typ" prefWidth="100"/>
            <TableColumn fx:id="amountColumn" text="Betrag" prefWidth="100"/>
            <TableColumn fx:id="categoryColumn" text="Kategorie" prefWidth="150"/>
            <TableColumn fx:id="dateColumn" text="Datum" prefWidth="120"/>
            <TableColumn fx:id="noteColumn" text="Notiz" prefWidth="250"/>
        </columns>
    </TableView>

</VBox>